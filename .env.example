# MongoDB Atlas connection string. Use the database name you want, for example:
# mongodb+srv://USER:PASSWORD@cluster.mongodb.net/autopaper?retryWrites=true&w=majority
MONGODB_URI=

# At least 32 characters. Generate a long random value and keep it secret.
JWT_SECRET=

# Local: http://localhost:3000
# Production: https://your-deployed-site-url
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend email sending.
RESEND_API_KEY=
EMAIL_FROM="AutoPaper <onboarding@resend.dev>"

# Optional. Use only while testing Resend before domain verification.
# If set, the app will only send verification/reset emails to this address.
EMAIL_TEST_RECIPIENT=

# Public contact and analytics values.
NEXT_PUBLIC_CONTACT_EMAIL=riteshworking247@gmail.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
