# Required: production MongoDB/Atlas connection string including database name.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/autopaper?retryWrites=true&w=majority

# Required for canonical URLs, sitemap, and robots metadata.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional public contact email shown on the contact page.
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
