# MongoDB Atlas connection string. Use the database name you want, for example:
# mongodb+srv://USER:PASSWORD@cluster.mongodb.net/autopaper?retryWrites=true&w=majority
MONGODB_URI=

# At least 32 characters. Generate a long random value and keep it secret.
JWT_SECRET=

# Local: http://localhost:3000
# Production: https://your-deployed-site-url
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail SMTP email sending.
# Use a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-character-google-app-password
EMAIL_FROM="AutoPaper <your-gmail-address@gmail.com>"

# Public contact and analytics values.
NEXT_PUBLIC_CONTACT_EMAIL=riteshworking247@gmail.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
